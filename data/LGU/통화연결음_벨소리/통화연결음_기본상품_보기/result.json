  "content": {
    "details": "<div class=\"c-page-section\">\n        <!-- <div class=\"top-img -mb-8n-5\">\n          <img\n            src=\"https://image.lguplus.com/static/pc-contents/images/fcmm/cnts/imge/20250423-041349-132-7Jg6xYdM.png\"\n            alt=\"통화연결음 가입이벤트! 매월 진행되는 가입 이벤트에 참여하고 경품도 받으세요!\"\n          />\n\n          <div class=\"qr_area\">\n            <span class=\"is-blind\">IOS Android QR</span>\n          </div>\n          <a\n            data-route\n            class=\"cl-def btn-musicbelling\"\n            href=\"https://lgudcb.com/47Gc9BB\"\n            target=\"_blank\"\n            title=\"새창열기\"\n            >뮤직벨링 설정하러 바로가기</a\n          >\n          <a\n            data-route\n            class=\"btn-detail-view\"\n            target=\"_blank\"\n            title=\"새창열기\"\n            href=\"https://ent.uplus.co.kr/ch/zwonp_u2\"\n            data-gtm-event-name=\"link_click\"\n            data-gtm-event-category=\"클릭\"\n            data-gtm-click-url=\"https://ent.uplus.co.kr/ch/zwonp_u2\"\n            data-gtm-event-label=\"컨텐츠 : 이벤트 바로가기\"\n            data-gtm-click-text=\"이벤트 바로가기\"\n            ><span class=\"blind\">이벤트 바로가기</span></a\n          >\n        </div> -->\n\n        <h2 class=\"h2\">서비스 내용</h2>\n        <div class=\"cv-sv-group\">\n          <p class=\"h5 sv-tit\">서비스별 요금</p>\n          <div class=\"row c-table\">\n            <table class=\"table b-table table-bordered\">\n              <caption>\n                서비스별 요금 : 서비스명, 월 이용금액(부가세포함), 내용, 서비스\n                가입에 대한 표\n              </caption>\n              <colgroup>\n                <col>\n                <col>\n                <col>\n                <col>\n              </colgroup>\n              <thead>\n                <tr>\n                  <th scope=\"col\">서비스명</th>\n                  <th scope=\"col\">월 이용금액<br>(부가세포함)</th>\n                  <th scope=\"col\">내용</th>\n                  <th scope=\"col\">서비스 가입</th>\n                </tr>\n              </thead>\n              <tbody>\n                <tr>\n                  <td scrope=\"row\" class=\"tb-point-b fw-b\">\n                    필링 라이트<br>\n                    (통화연결음_매달1곡)\n                  </td>\n                  <td class=\"tb-point-b\">1,540원</td>\n                  <td class=\"c-cell-left\">\n                    <span class=\"color_violet fw-b\">\n                      * 매달 1곡! 통화연결음을 매달 새롭게 설정하세요.\n                    </span>\n                    <ul class=\"c-bullet-type-circle grow-1\">\n                      <li>통화연결음 매달 1건 무료</li>\n                      <li>내가 사용하거나 친구에게 선물 가능</li>\n                    </ul>\n                  </td>\n                  <td>\n                    <a data-route=\"\" class=\"c-link-arr-1 cl-def\" href=\"/mobile/plan/addon/addon-call-msg/LRZ0001036\" data-gtm-event-name=\"link_click\" data-gtm-event-category=\"클릭\" data-gtm-event-action=\"콘텐츠 영역 - 링크 클릭\" data-gtm-event-label=\"컨텐츠 : 필링라이트 페이지로 이동\" data-gtm-click-url=\"https://www.lguplus.com/mobile/plan/addon/addon-call-msg/LRZ0001036\" data-gtm-click-location=\"콘텐츠 영역\" data-gtm-click-direction=\"내부\" data-gtm-click-text=\"필링라이트 페이지로 이동\">자세히 보기</a>\n                  </td>\n                </tr>\n                <tr>\n                  <td scrope=\"row\" class=\"tb-point-b fw-b\">\n                    오토롱 필링 라이트<br>\n                    (통화연결음_매월 자동변경)\n                  </td>\n                  <td class=\"tb-point-b\">1,540원</td>\n                  <td class=\"c-cell-left\">\n                    <span class=\"color_violet fw-b\">\n                      * 장르만 고르면, 매달 자동으로 통화연결음이 변경되어\n                      편리해요.\n                    </span>\n                    <ul class=\"c-bullet-type-circle grow-1\">\n                      <li>통화연결음 매달 1회 자동 변경</li>\n                      <li>매달 1일 오전, 원하는 장르의 음악으로 변경</li>\n                    </ul>\n                  </td>\n                  <td>\n                    <a data-route=\"\" class=\"c-link-arr-1 cl-def\" href=\"/mobile/plan/addon/addon-call-msg/LRZ0000945\" data-gtm-event-name=\"link_click\" data-gtm-event-category=\"클릭\" data-gtm-event-action=\"콘텐츠 영역 - 링크 클릭\" data-gtm-event-label=\"컨텐츠 : 오토롱 필링 라이트 페이지로 이동\" data-gtm-click-url=\"https://www.lguplus.com/mobile/plan/addon/addon-call-msg/LRZ0000945\" data-gtm-click-location=\"콘텐츠 영역\" data-gtm-click-direction=\"내부\" data-gtm-click-text=\"오토롱 필링 라이트 페이지로 이동\">자세히 보기</a>\n                  </td>\n                </tr>\n                <tr>\n                  <td scrope=\"row\" class=\"tb-point-b fw-b\">\n                    오토롱 필링<br>\n                    (통화연결음_매주 자동변경)\n                  </td>\n                  <td class=\"tb-point-b\">2,090원</td>\n                  <td class=\"c-cell-left\">\n                    <span class=\"color_violet fw-b\">\n                      * 매주 자동 변경! 월요일마다 새 음악으로 리프레시가\n                      필요하신가요?\n                    </span>\n                    <ul class=\"c-bullet-type-circle grow-1\">\n                      <li>통화연결음 매주 1회 자동 변경</li>\n                      <li>매주 월요일 오전, 원하는 장르의 음악으로 변경</li>\n                    </ul>\n                  </td>\n                  <td>\n                    <a data-route=\"\" class=\"c-link-arr-1 cl-def\" href=\"/mobile/plan/addon/addon-call-msg/LRZ0000782\" data-gtm-event-name=\"link_click\" data-gtm-event-category=\"클릭\" data-gtm-event-action=\"콘텐츠 영역 - 링크 클릭\" data-gtm-event-label=\"컨텐츠 : 오토롱 필링 페이지로 이동\" data-gtm-click-url=\"https://www.lguplus.com/mobile/plan/addon/addon-call-msg/LRZ0000782\" data-gtm-click-location=\"콘텐츠 영역\" data-gtm-click-direction=\"내부\" data-gtm-click-text=\"오토롱 필링 페이지로 이동\">자세히 보기</a>\n                  </td>\n                </tr>\n                <tr>\n                  <td scrope=\"row\" class=\"tb-point-b fw-b\">필링_무제한</td>\n                  <td class=\"tb-point-b\">4,840원</td>\n                  <td class=\"c-cell-left\">\n                    <span class=\"color_violet fw-b\">\n                      * 원하는 만큼 자유롭게 통화연결음을 설정하고 싶을 때!\n                    </span>\n                    <ul class=\"c-bullet-type-circle grow-1\">\n                      <li>통화연결음 음원 무제한 이용</li>\n                    </ul>\n                  </td>\n                  <td>\n                    <a data-route=\"\" class=\"c-link-arr-1 cl-def\" href=\"/mobile/plan/addon/addon-call-msg/LRZ0000999\" data-gtm-event-name=\"link_click\" data-gtm-event-category=\"클릭\" data-gtm-event-action=\"콘텐츠 영역 - 링크 클릭\" data-gtm-event-label=\"컨텐츠 : 필링라이트 페이지로 이동\" data-gtm-click-url=\"https://www.lguplus.com/mobile/plan/addon/addon-call-msg/LRZ0000999\" data-gtm-click-location=\"콘텐츠 영역\" data-gtm-click-direction=\"내부\" data-gtm-click-text=\"필링라이트 페이지로 이동\">자세히 보기</a>\n                  </td>\n                </tr>\n              </tbody>\n            </table>\n          </div>\n        </div>\n\n        <div class=\"cv-sv-group\">\n          <dl class=\"cv-exp-list\">\n            <dt><span class=\"cl-def\">✔</span> 필링, 이럴 때 이용해 보세요.</dt>\n            <dd>\n              <ul class=\"c-bullet-type-circle grow-1\">\n                <li>\n                  내게 전화를 건 상대방에게 단조로운 기계음 대신 나만의 개성을\n                  표현할 수 있는 음악을 들려주고 싶을 때\n                </li>\n                <li>\n                  매월 콘텐츠 변경을 원하지 않을 경우 기본 상품을 이용하실 수\n                  있어요.\n                  <a data-route=\"\" class=\"c-link-arr-1-s\" href=\"/mobile/plan/addon/addon-ringtones-callertunes/LRZ0000515\">자세히 보기</a>\n                </li>\n              </ul>\n            </dd>\n            <dt>\n              <span class=\"cl-def\">✔</span> 오토롱, 이럴 때 이용해 보세요.\n            </dt>\n            <dd>\n              <ul class=\"c-bullet-type-circle grow-1\">\n                <li>좋아하는 장르의 음악을 바꿔가며 설정하고 싶을 때</li>\n                <li>어떤 곡을 통화연결음으로 설정해야 할지 고민될 때</li>\n                <li>늘 같은 통화연결음이 지겨울 때</li>\n              </ul>\n            </dd>\n            <dt>\n              <span class=\"cl-def\">✔</span> 통화연결음과 벨소리, MP3를 저렴하게\n              이용하는 방법!\n            </dt>\n            <dd>\n              <a data-route=\"\" class=\"c-link-arr-1 cl-def\" href=\"/mobile/plan/addon/addon-call-msg/Z202507082\">통화연결음 할인상품 바로가기</a>\n            </dd>\n            <dt>\n              <span class=\"cl-def\">✔</span> 인사말 통화연결음을 설정하고 싶다면?\n            </dt>\n            <dd>\n              <a data-route=\"\" class=\"c-link-arr-1 cl-def\" href=\"/mobile/plan/addon/addon-ringtones-callertunes/Z202507083\">인사말 추천구성 보기</a>\n            </dd>\n          </dl>\n        </div>\n      </div>",
