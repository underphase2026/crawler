 \t\t                  </th:block> -->\n<!-- \t\t                </div> -->\n<!-- \t\t            </th:block>               -->\n\t            \n\t            <!-- //가입가능 상품 -->\n\t            <!-- 가입중단 상품 -->\n\t            \n\t            <!-- //가입중단 상품 -->\n\t            <!-- 가입불가 상품 -->\n\t            \n\t            <!-- //가입불가 상품 -->\n\t        \n\t    \n\t    <!-- //미가입 -->\n\t    <!-- 가입 -->\n\t    \n\t    <!-- //가입 -->\n      \t            \n\t            <!-- //버튼 -->\n\t            \n\t            <!-- 기본제공영역 -->\n                \n        <!-- 기본제공영역 -->\n        <div class=\"adaptive-float-area-summary C\">\n            <!-- 무선 요금제 -->\n            \n            <!-- //무선 요금제 -->  \n            <!-- 무선 부가서비스 -->\n            \n            <!-- //무선 부가서비스 -->  \n            <!-- 로밍 요금제 -->\n            \n            \n            <!-- //로밍 요금제 -->\n        </div>\n        <!-- //기본제공영역 -->\n      \n\t            <!-- //기본제공영역 -->\n\t            \n\t            <!-- SKT만의혜택영역 -->\n\t            \n\t            <!-- //SKT만의혜택영역 -->\n\t\n\t            <!-- 이용중인 상품영역 -->\n\t            \n\t    <!-- 이용중인 상품영역 -->\n\t    \n\t    \n\t       \t\n\t      \n\t          <!-- 인터넷 요금제, 전화 요금제, TV 요금제, 결합 요금제 -->\n\t          \n\t      \n\t    \n\t    <!-- //이용중인 상품영역 -->\n  \n\t            <!-- //이용중인 상품영역 -->\n\t        </div>\n<hr class=\"section-divider\">\n<div class=\"adaptive-float-area-price\">\n           <div class=\"adaptive-float-area-price-tit\" style=\"word-break: break-all;\">T가족모아데이터</div>\n           <!-- //무선 요금제 or 결합상품 -->\n           \n           <!-- //무선 부가서비스 or 로밍상품 or 유선 부가서비스(인터넷 부가서비스 or 전화 부가서비스 or TV 부가서비스) -->\n           <div class=\"adaptive-float-area-price-case\">이용요금(부가세 포함)</div>\n           <!-- //유선 요금제(인터넷 요금제 or 전화 요금제 or TV 요금제) -->\n           \n           <div class=\"adaptive-float-area-price-money\">상세참조\n           \t\t\n           </div>\n           \n\t           \n\t       \n        </div>\n<hr class=\"section-divider\">\n<div class=\"adaptive-float-area-summary C\">\n            <!-- 무선 요금제 -->\n            \n            <!-- //무선 요금제 -->  \n            <!-- 무선 부가서비스 -->\n            \n            <!-- //무선 부가서비스 -->  \n            <!-- 로밍 요금제 -->\n            \n            \n            <!-- //로밍 요금제 -->\n        </div>\n<hr class=\"section-divider\">\n<ul class=\"idpt-faq\">\n                <!-- 190712 삭제 -->\n                <!-- <li>\n                    \n<div class=\"idpt-faq-question\" role=\"button\" aria-pressed=\"false\">\n                        <img src=\"https://cdnw.tworld.co.kr/img/product/icon-question_m.png\" class=\"idpt-mobile\" alt=\"질문\">\n                        <img src=\"/poc/img/product/icon-question.png\" class=\"idpt-pc\" alt=\"질문\">\n                        <p>기본 제공량과 가족 공유 데이터를 모두 소진하면, 요금이 초과로 청구되는건가요?</p>\n                        <img src=\"https://cdnw.tworld.co.kr/img/product/faq-arrow_m.png\" class=\"idpt-mobile faq-arrow\" alt=\"답변 펼쳐보기\">\n                        <img src=\"/poc/img/product/faq-arrow.png\" class=\"idpt-pc faq-arrow\" alt=\"답변 펼쳐보기\">\n                    </div><div class=\"idpt-faq-answer\">\n                        <img src=\"https://cdnw.tworld.co.kr/img/product/icon-answer_m.png\" class=\"idpt-mobile\" alt=\"답변\">\n                        <img src=\"/poc/img/product/icon-answer.png\" class=\"idpt-pc\" alt=\"답변\">\n                        <p>아니오, 청구되지 않습니다.<br>데이터 소진 후에도 ‘무제한 안심옵션’혜택으로 T플랜 스몰은 최대 400Kbps, T플랜 미디엄은 최대 1Mbps, T플랜 라지와 패밀리는 최대 5Mbps의 속도 제어로 계속 쓸 수 있어요.</p>\n                    </div></li> -->\n                <!-- //190712 삭제 -->\n                \n<li>\n                    \n<div class=\"idpt-faq-question\" role=\"button\" aria-pressed=\"false\">\n                        \n                        \n                        <p>가족에게 공유했던 데이터를 취소할 수 있나요?</p>\n                        \n                        \n                    </div><div class=\"idpt-faq-answer\" style=\"display: none;\">\n                        \n                        \n                        <p>네. 공유한 데이터 중 아직 가족이 사용하지 않은 데이터는 나만 사용할 수 있는 데이터로 변경할 수 있습니다.</p>\n                    </div></li>\n                \n<li>\n                    \n<div class=\"idpt-faq-question\" role=\"button\" aria-pressed=\"false\">\n                        \n                        \n                        <p>기본 제공 데이터를 모두 T가족모아데이터 가족 공유하기, 데이터 선물하기, 2nd 디바이스 공유 데이터(함께쓰기 등), 테더링으로 사용할 수 있나요?\n</p>\n                        \n                        \n                    </div><div class=\"idpt-faq-answer\" style=\"display: none;\">\n                        \n                        \n                        <!-- 230420 [MOZOP002-26745] -->\n                        <p>아니오, 요금제별로 우측 통합 한도 내에서 사용 가능합니다.<br>예를 들어, 패밀리 요금제 사용자의 경우, 최대 40GB를 가족 공유 데이터 및 선물하기, 함께쓰기, 2nd 디바이스 공유 데이터로 사용하게 됩니다.<br>따라서 공유 데이터를 모두 T 가족모아 데이터로 설정 시 데이터 선물하기는 이용할 수 없으니 꼭 유의하세요.</p>\n                        \n<table class=\"idpt-tbl-discount\" summary=\"요금제별 공유 데이터 안내 테이블은 요금제명, T 가족모아 데이터, 선물하기, 함께쓰기, 2nd 디바이스 공유로 구성되어 있습니다.\"><caption>요금제별 공유 데이터 안내</caption><colgroup>\n                                <col style=\"width:16%\">\n                                <col style=\"width:21.2%\">\n                                <col style=\"width:25%\">\n                                <col style=\"width:auto;\">\n                            </colgroup>\n                            \n<thead><tr><th scope=\"colgroup\" colspan=\"2\">\n\n요금제명\n</th><th scope=\"col\">\n\nT 가족모아 데이터\n</th><th scope=\"col\">\n\n선물하기, 함께쓰기,<br class=\"idpt-pc\"> 2nd 디바이스 공유\n</th></tr></thead>\n                            \n<tbody><tr><td rowspan=\"5\">\n\nT플랜/ 다이렉트플랜 LTE\n</td><!-- 200520 [OP002-8343] 수정_06 -->\n                                \n<td>\n\n안심2.5G\n</td><td rowspan=\"3\">\n\n공유불가\n</td><td>\n\n2.5GB\n</td></tr><tr><td>\n\n안심4G\n</td><td>\n\n4GB\n</td></tr><tr><td>\n\n에센스\n</td><td>\n\n15GB\n</td></tr><tr><td>\n\n스페셜\n</td><td colspan=\"2\">\n\n40GB\n</td></tr><tr><td>\n\n맥스\n</td><td colspan=\"2\">\n\n80GB\n</td></tr><tr><td rowspan=\"5\">\n\nT플랜\n</td><td>\n\n스몰\n</td><td rowspan=\"3\">\n\n공유불가\n</td><td>\n\n1.2GB\n</td></tr><tr><td>\n\n미디엄\n</td><td>\n\n4GB\n</td></tr><tr><td>\n\n라지\n</td><td>\n\n30GB\n</td></tr><tr><td>\n\n패밀리\n</td><td colspan=\"2\">\n\n40GB\n</td></tr><tr><td>\n\nData<br class=\"idpt-mobile\"> 인피니티\n</td><td colspan=\"2\">\n\n80GB\n</td></tr><tr><td rowspan=\"4\">\n\nT플랜 시니어\n</td><td>\n\n안심2.8G\n</td><td rowspan=\"3\">\n\n공유불가\n</td><td rowspan=\"2\">\n\n기본 데이터 제공량 내 사용가능\n</td></tr><tr><td>\n\n안심4.5G\n</td></tr><tr><td>\n\n에센스\n</td><td>\n\n30GB\n</td></tr><tr><td>\n\n스페셜\n</td><td colspan=\"2\">\n\n40GB\n</td></tr><tr><td>\n\n0플랜\n</td><td>\n\n라지\n</td><td colspan=\"2\">\n\n40GB\n</td></tr></tbody></table>\n                        <!-- //230420 [MOZOP002-26745] -->\n                    </div></li>\n                <!-- 190712 삭제 -->\n                <!-- <li>\n                    \n<div class=\"idpt-faq-question\" role=\"button\" aria-pressed=\"false\">\n                        <img src=\"https://cdnw.tworld.co.kr/img/product/icon-question_m.png\" class=\"idpt-mobile\" alt=\"질문\">\n                        <img src=\"/poc/img/product/icon-question.png\" class=\"idpt-pc\" alt=\"질문\">\n                        <p>테더링은 얼마나 사용할 수 있나요?</p>\n                        <img src=\"https://cdnw.tworld.co.kr/img/product/faq-arrow_m.png\" class=\"idpt-mobile faq-arrow\" alt=\"답변 펼쳐보기\">\n                        <img src=\"/poc/img/product/faq-arrow.png\" class=\"idpt-pc faq-arrow\" alt=\"답변 펼쳐보기\">\n                    </div><div class=\"idpt-faq-answer\">\n                        <img src=\"https://cdnw.tworld.co.kr/img/product/icon-answer_m.png\" class=\"idpt-mobile\" alt=\"답변\">\n                        <img src=\"/poc/img/product/icon-answer.png\" class=\"idpt-pc\" alt=\"답변\">\n                        <p>요금제별 기본 데이터 내에서의 테더링 이용한도는 우측과 같습니다. 단, 공유 데이터 (가족공유, 선물하기, 함께쓰기, 2nd 디바이스 공유)와는 별도로 차감됩니다.</p><table class=\"idpt-tbl-discount\"><caption>요금제별 공유 데이터</caption><colgroup><col style=\"width:25%\"><col style=\"width:30%\"><col style=\"width:auto\"></colgroup><thead><tr><th colspan=\"2\">\n\n요금제명\n</th><th>\n\n이용한도\n</th></tr></thead><tbody><tr><td rowspan=\"2\">\n\n5GX 플랜\n</td><td>\n\n프라임\n</td><td>\n\n30GB\n</td></tr><tr><td>\n\n플래티넘\n</td><td>\n\n50GB\n</td></tr><tr><td rowspan=\"5\">\n\nT플랜\n</td><td>\n\n안심2.5G\n</td><td>\n\n2.5GB\n</td></tr><tr><td>\n\n안심4G\n</td><td>\n\n4GB\n</td></tr><tr><td>\n\n에센스\n</td><td>\n\n15GB\n</td></tr><tr><td>\n\n스페셜\n</td><td>\n\n20GB\n</td></tr><tr><td>\n\n맥스\n</td><td>\n\n30GB\n</td></tr><tr><td rowspan=\"3\">\n\nT플랜\n</td><td>\n\n라지\n</td><td>\n\n15GB\n</td></tr><tr><td>\n\n패밀리\n</td><td>\n\n20GB\n</td></tr><tr><td>\n\nData 인피니티\n</td><td>\n\n30GB\n</td></tr><tr><td>\n\n0플랜\n</td><td>\n\n라지\n</td><td>\n\n20GB\n</td></tr></tbody></table>\n                        <p class=\"answer-title\">테더링 설정방법</p>\n                        <p class=\"answer-txt with-title\">아이폰 설정</p>\n                        \n<div class=\"answer-img\">\n                            <img src=\"https://cdnw.tworld.co.kr/img/product/iphone-setting_m.png\" class=\"idpt-mobile\" alt=\"설정 > 개인용 핫스팟\">\n                            <img src=\"/poc/img/product/iphone-setting.png\" class=\"idpt-pc\" alt=\"설정 > 개인용 핫스팟\">\n                        </div><p class=\"answer-txt\">안드로이드 설정</p>\n                        \n<div class=\"answer-img\">\n                            <img src=\"https://cdnw.tworld.co.kr/img/product/android-setting_m.png\" class=\"idpt-mobile\" alt=\"연결 > 모바일 핫스팟 및 테더링\">\n                            <img src=\"/poc/img/product/android-setting.png\" class=\"idpt-pc\" alt=\"연결 > 모바일 핫스팟 및 테더링\">\n                        </div></div></li> -->\n                <!-- //190712 삭제 -->\n                \n<li>\n                    \n<div class=\"idpt-faq-question\" role=\"button\" aria-pressed=\"false\">\n                        \n                        \n                        <p>저는 Data 인피니티(또는 패밀리)사용자인데요. 가족 별 데이터 및 요금제의 남은 데이터양은 어디서 확인하나요?</p>\n                        \n                        \n                    </div><div class=\"idpt-faq-answer\">\n                        \n                        \n                        <p>my T &gt; ‘나의 데이터·통화’에서 나의 잔여 데이터양은 물론 공유된 가족간 사용 데이터양도 확인 가능합니다.</p>\n                        \n<div class=\"answer-img\">\n                            \n                            \n                        </div></div></li>\n            \n</ul>",
    "usageGuidelines": "<div class=\"adaptive-belt-w1000\"><div class=\"idpt-benefit no-button benefit-white\">\n            <p class=\"benefit-title\">가족끼리 최대 80GB까지 데이터 공유</p><!-- 230420 [MOZOP002-26745] -->\n            <p class=\"benefit-desc\">T플랜 맥스, Data 인피니티, 다이렉트LTE 맥스는 80GB, T플랜 스페셜, 다이렉트LTE 스페셜, T플랜 시니어 스페셜, 패밀리, 0플랜 라지는 40GB까지 가족과 공유할 수 있고, FLO 매월 100회 무료 듣기가 제공됩니다.</p><!-- 230420 [MOZOP002-26745] -->\n            <!-- 190712 수정 -->\n            \n<ul class=\"benefit-data list03 clearfix\">\n                \n<li>\n                    \n                    \n                    데이터 공유<br>최대 80GB <!-- 190403_수정 -->\n                </li>\n                \n<li>\n                    \n                    \n                    FLO 매월 100회<br>무료\n                </li>\n                \n<li>\n                    \n                    \n                    안심옵션<br>무료제공\n                </li>\n            \n</ul>\n            <!-- //190712 수정 -->\n        </div><!--// 가족끼리 최대 80GB까지 데이터 공유 -->        <!-- 가족끼리 데이터 공유 -->        <div class=\"idpt-benefit no-button benefit-gray\">\n            \n<ul class=\"idpt-title-bg-box\">\n                \n<li>\n                    <p class=\"benefit-title\">가족끼리 데이터 공유</p>\n                    \n<div class=\"display-flex\">\n                        \n                        \n                        \n<div>\n                            <p class=\"sub-title\">최대 80GB 까지 공유</p> <!-- 190403_수정 -->\n                             <p class=\"sub-txt\">T플랜 맥스, Data 인피니티, 다이렉트LTE 맥스는 80GB, T플랜 스페셜, 다이렉트LTE 스페셜, T플랜 시니어 스페셜, 패밀리, 0플랜 라지는 최대 40GB까지 가족들에게 공유할 수 있습니다.</p> <!-- 230420 [MOZOP002-26745] -->\n                        </div></div></li>\n                \n<li>\n                    <p class=\"benefit-title\">FLO 매월 100회 무료 듣기 제공</p>\n                    \n<div class=\"display-flex\">\n                        \n                        \n                        \n<div>\n                            <p class=\"sub-title\">매 월 100회 듣기 + 전용 데이터 제공</p>\n                            <p class=\"sub-txt\">FLO에서 매 월 100회 음악을 들을 수 있으며, FLO 전용 데이터도 제공됩니다.</p> <!-- 190520_수정 -->\n                        </div></div></li>\n                <!-- 190712 추가 -->\n                \n<li>\n                    <p class=\"benefit-title\">안심옵션 무료 제공 </p>\n                    \n<div class=\"display-flex\">\n                        \n                        \n                        \n<div>\n                            <p class=\"sub-title\">스몰 사용시, 안심옵션 무료 제공</p>\n                            <p class=\"sub-txt\">스몰 사용시, 안심옵션을 무료로 제공합니다.<br> (데이터 모두 사용 후, 최대 400kbps로 속도제어)</p>\n                        </div></div></li>\n                <!-- //190712 추가 -->\n            \n</ul>\n        </div><!--// 가족끼리 데이터 공유 -->        <!-- 가족끼리 데이터 공유 -->        <div class=\"idpt-benefit no-button no-padding benefit-white\">\n            <p class=\"benefit-title\">T 가족모아 데이터를 쓰면 어떻게 달라질까요?</p>\n            <p class=\"benefit-desc\">통신비는 절감되고, 데이터의 양은 늘어납니다.</p>\n            \n<div class=\"benefit-img family-moa\">\n                \n                \n            </div></div><!--// 가족끼리 데이터 공유 -->        <!-- 가입 대상 안내 -->        <div class=\"idpt-benefit benefit-gray\">\n            <p class=\"benefit-title\">가입대상</p>\n            \n<div class=\"idpt-join-info\">\n                \n<div class=\"benefit-img\">\n                    \n                    \n                </div><div class=\"join-info-txt\">\n                    <!-- 190712 수정 -->\n                                        <p>T플랜 맥스/스페셜/에센스/안심4G/안심2.5G,<br>T플랜 Data인피니티/패밀리/라지/미디엄/레귤러/스몰, T플랜 시니어 스페셜/에센스/안심4.5G/안심2.8G, 0플랜 라지/미디엄/스몰,<br>다이렉트LTE 맥스/스페셜/에센스/안심4G/안심2.5G 및 band/T시그니처요금제/(LTE)ZEM플랜 베스트 중 하나를 이용중인 고객님<br>※ T플랜 세이브 / 다이렉트LTE 세이브 / T플랜 시니어 세이브는 가입불가<br><br>단, 가입 시 가족 구성원 중 T플랜 맥스 / T플랜 스페셜 / 패밀리 / Data 인피니티, 다이렉트LTE 맥스 / 다이렉트LTE 스페셜, T플랜 시니어 스페셜, 0플랜 라지 요금제 가입자가 있어야 데이터 공유가 가능합니다.</p>\n                    <!-- //190712 수정 -->\n                </div></div><div class=\"benefit-button\">\n                <a href=\"javascript:void(0)\" data-contents=\"0\" class=\"button-more\">더 알아보기</a>\n            </div></div><!--// 가입 대상 안내 -->        <!-- 이용요금 안내 -->        <div class=\"idpt-benefit no-button benefit-white\">\n            <p class=\"benefit-title\">이용요금</p>\n            \n<div class=\"idpt-charge-info\">\n                \n<div class=\"charge\">\n                    <p class=\"navy with-icon\">무료</p>\n                </div></div><ul class=\"idpt-dot-list\">\n                \n<li>T 가족모아 데이터는 가족간 데이터 공유를 위한 부가서비스로 이용 요금은 무료입니다.</li>\n            \n</ul>\n        </div><!--// 이용요금 안내 -->        <!-- 신청방법 -->        <div class=\"idpt-benefit no-button benefit-gray\">\n            <p class=\"benefit-title\">신청방법</p>\n            \n<ul class=\"idpt-circle-list navy\">\n                \n<li class=\"clearfix\">\n                    <p class=\"num\">1</p>\n                    \n<div class=\"txt-area\">\n                        <p class=\"circle-list-title\">가족 대표회선이 T플랜 맥스/ T플랜 스페셜/ 패밀리/ Data인피니티, T플랜 시니어 스페셜, 0플랜 라지 , 다이렉트LTE 맥스/다이렉트LTE 스페셜 요금제 이용 중 인지 확인하기<br><br> T 가족모아 데이터를 신청 가능한 요금제를 이용 중 인지 확인 하기</p>\n                        <p class=\"circle-list-txt\">상단의 ‘가입 대상 안내’에서 신청 가능한 요금제를 확인하세요.</p>\n                    </div><div class=\"arrow\">&nbsp;</div></li>\n                \n<li class=\"clearfix\">\n                    <p class=\"num\">2</p>\n                    \n<div class=\"txt-area\">\n                        <p class=\"circle-list-title\">T 가족모아 데이터 신청하기</p>\n                        <p class=\"circle-list-txt\">SK텔레콤 공식인증대리점 또는 지점에서 신청 가능합니다. (가족관계증빙서류 제출 필수)</p>\n                    </div><div class=\"arrow\">&nbsp;</div></li>\n                \n<li class=\"clearfix\">\n                    <p class=\"num\">3</p>\n                    \n<div class=\"txt-area\">\n                        <p class=\"circle-list-title\">가족관계 인증하기</p>\n                        <p class=\"circle-list-txt\">가족증빙서류를 제출해서 가족 관계를 인증하시면 됩니다.</p><p class=\"circle-list-txt\">※ 가족관계 증명 서류는 3개월 이내 발급한 가족관계증명서와 주민등록표등본 중 1가지의 원본 또는 사본을 준비해 주시기 바랍니다.</p><!-- 230307 [MOZOP002-25885] -->\n                    </div></li>\n            \n</ul>\n        </div><!--// 신청방법 -->        <!-- 데이터 공유 방법 -->        <div class=\"idpt-benefit no-button benefit-white family-moa\">\n            <p class=\"benefit-title\">데이터 공유 방법</p>\n            <p class=\"benefit-desc\">T플랜 맥스,T플랜 스페셜, 패밀리, Data 인피니티, T플랜 시니어 스페셜, 0플랜 라지, 다이렉트LTE 맥스,다이렉트LTE 스페셜 요금제의 공유 가능한 데이터 내에서 결합한 가족들에게 데이터를 공유하여 이용할 수 있습니다.</p>\n            <p class=\"family-moa-title\">공유 데이터 설정 화면으로 이동하기</p>\n            <p class=\"benefit-txt align-center\">T world 앱을 실행하여 ‘MY’ 탭에서 로그인 후 ‘MY’ 버튼을 클릭하여 ‘T 가족모아 데이터’를 선택합니다.</p><!-- 230420 [MOZOP002-26745] -->\n            \n            \n            \n            <p class=\"benefit-txt align-center\">T 가족모아 데이터 화면에서 ‘공유’ 버튼을 누르면<br class=\"idpt-mobile\"> 설정 화면으로 이동합니다.</p><!-- 230420 [MOZOP002-26745] -->\n            \n            \n            \n<div class=\"inside-box\">\n                \n                \n                <p class=\"family-moa-title with-num\">원하는 순간 바로 공유할 수 있는<br class=\"idpt-mobile\"> 공유 데이터 설정하기</p>\n                <p class=\"benefit-txt align-center\">‘바로 공유 가능 데이터’를 확인하여,<br class=\"idpt-mobile\"> 1GB 단위로 공유할 데이터양 입력한 후, 즉시 공유 신청</p>\n                \n                \n                \n                \n                <p class=\"family-moa-title with-num\">매월 1일, 데이터가 자동으로 공유되는<br class=\"idpt-mobile\"> 공유 미리 설정하기</p>\n                <p class=\"benefit-txt align-center\">‘매월 공유할 데이터양’을 입력한 후, 설정 저장</p>\n                \n                \n                \n<ul class=\"idpt-dot-list\">\n                    \n<li>다음 달 1일부터 적용</li>\n                \n</ul>\n            </div></div><!--// 데이터 공유 방법 -->        <!-- 가족별 이용한도 설정 -->        <div class=\"idpt-benefit no-button benefit-gray family-moa\">\n            <p class=\"benefit-title\">가족별 이용한도 설정</p>\n            <p class=\"benefit-desc\">공유된 데이터의 효율적인 사용을 위해 가족 구성원 별로 공유 데이터의 양을 제한 할 수 있습니다.</p>\n            <p class=\"family-moa-title\">나의 T 가족모아 데이터</p>\n            <p class=\"benefit-txt align-center\">나의 이용 가능한 T 가족모아 데이터 잔여량을 의미합니다.<br>(대표를 통해 한도가 설정된 고객의 경우,<br class=\"idpt-mobile\"> 한도 기준의 남은 데이터양)</p>\n            \n            \n            <!--<img src=\"https://cdnw.tworld.co.kr/img/product/data-share05-01_m.png\" class=\"idpt-mobile family-moa-img\" alt=\"\">--><!-- 230420 [MOZOP002-26745] -->\n            \n<div class=\"inside-box\">\n                <p class=\"family-moa-title idpt-no-margin\">T 가족모아 데이터 이용한도 설정</p>\n                <p class=\"benefit-txt align-center\">이용한도 옆 ‘설정’ 버튼을 클릭하여<br class=\"idpt-mobile\"> 이용한도를 설정할 수 있습니다.<br>(‘설정’ 버튼은 가족대표에게만 나타납니다.)</p>\n                \n                \n                \n            </div></div><!--// 가족별 이용한도 설정 -->        <!-- T 가족모아 데이터 이런 내용이 궁금해요! -->        <div class=\"idpt-benefit no-button no-padding benefit-white\" style=\"padding-bottom:0;\">\n            <p class=\"benefit-title\">T 가족모아 데이터<br class=\"idpt-mobile\"> 이런 내용이 궁금해요!</p>\n            \n<ul class=\"idpt-faq\">\n                <!-- 190712 삭제 -->\n                <!-- <li>\n                    \n<div class=\"idpt-faq-question\" role=\"button\" aria-pressed=\"false\">\n                        <img src=\"https://cdnw.tworld.co.kr/img/product/icon-question_m.png\" class=\"idpt-mobile\" alt=\"질문\">\n                        <img src=\"/poc/img/product/icon-question.png\" class=\"idpt-pc\" alt=\"질문\">\n                        <p>기본 제공량과 가족 공유 데이터를 모두 소진하면, 요금이 초과로 청구되는건가요?</p>\n                        <img src=\"https://cdnw.tworld.co.kr/img/product/faq-arrow_m.png\" class=\"idpt-mobile faq-arrow\" alt=\"답변 펼쳐보기\">\n                        <img src=\"/poc/img/product/faq-arrow.png\" class=\"idpt-pc faq-arrow\" alt=\"답변 펼쳐보기\">\n                    </div><div class=\"idpt-faq-answer\">\n                        <img src=\"https://cdnw.tworld.co.kr/img/product/icon-answer_m.png\" class=\"idpt-mobile\" alt=\"답변\">\n                        <img src=\"/poc/img/product/icon-answer.png\" class=\"idpt-pc\" alt=\"답변\">\n                        <p>아니오, 청구되지 않습니다.<br>데이터 소진 후에도 ‘무제한 안심옵션’혜택으로 T플랜 스몰은 최대 400Kbps, T플랜 미디엄은 최대 1Mbps, T플랜 라지와 패밀리는 최대 5Mbps의 속도 제어로 계속 쓸 수 있어요.</p>\n                    </div></li> -->\n                <!-- //190712 삭제 -->\n                \n<li>\n                    \n<div class=\"idpt-faq-question\" role=\"button\" aria-pressed=\"false\">\n                        \n                        \n                        <p>가족에게 공유했던 데이터를 취소할 수 있나요?</p>\n                        \n                        \n                    </div><div class=\"idpt-faq-answer\" style=\"display: none;\">\n                        \n                        \n                        <p>네. 공유한 데이터 중 아직 가족이 사용하지 않은 데이터는 나만 사용할 수 있는 데이터로 변경할 수 있습니다.</p>\n                    </div></li>\n                \n<li>\n                    \n<div class=\"idpt-faq-question\" role=\"button\" aria-pressed=\"false\">\n                        \n                        \n                        <p>기본 제공 데이터를 모두 T가족모아데이터 가족 공유하기, 데이터 선물하기, 2nd 디바이스 공유 데이터(함께쓰기 등), 테더링으로 사용할 수 있나요?\n</p>\n                        \n                        \n                    </div><div class=\"idpt-faq-answer\" style=\"display: none;\">\n                        \n                        \n                        <!-- 230420 [MOZOP002-26745] -->\n                        <p>아니오, 요금제별로 우측 통합 한도 내에서 사용 가능합니다.<br>예를 들어, 패밀리 요금제 사용자의 경우, 최대 40GB를 가족 공유 데이터 및 선물하기, 함께쓰기, 2nd 디바이스 공유 데이터로 사용하게 됩니다.<br>따라서 공유 데이터를 모두 T 가족모아 데이터로 설정 시 데이터 선물하기는 이용할 수 없으니 꼭 유의하세요.</p>\n                        \n<table class=\"idpt-tbl-discount\" summary=\"요금제별 공유 데이터 안내 테이블은 요금제명, T 가족모아 데이터, 선물하기, 함께쓰기, 2nd 디바이스 공유로 구성되어 있습니다.\"><caption>요금제별 공유 데이터 안내</caption><colgroup>\n                                <col style=\"width:16%\">\n                                <col style=\"width:21.2%\">\n                                <col style=\"width:25%\">\n                                <col style=\"width:auto;\">\n                            </colgroup>\n                            \n<thead><tr><th scope=\"colgroup\" colspan=\"2\">\n\n요금제명\n</th><th scope=\"col\">\n\nT 가족모아 데이터\n</th><th scope=\"col\">\n\n선물하기, 함께쓰기,<br class=\"idpt-pc\"> 2nd 디바이스 공유\n</th></tr></thead>\n                            \n<tbody><tr><td rowspan=\"5\">\n\nT플랜/ 다이렉트플랜 LTE\n</td><!-- 200520 [OP002-8343] 수정_06 -->\n                                \n<td>\n\n안심2.5G\n</td><td rowspan=\"3\">\n\n공유불가\n</td><td>\n\n2.5GB\n</td></tr><tr><td>\n\n안심4G\n</td><td>\n\n4GB\n</td></tr><tr><td>\n\n에센스\n</td><td>\n\n15GB\n</td></tr><tr><td>\n\n스페셜\n</td><td colspan=\"2\">\n\n40GB\n</td></tr><tr><td>\n\n맥스\n</td><td colspan=\"2\">\n\n80GB\n</td></tr><tr><td rowspan=\"5\">\n\nT플랜\n</td><td>\n\n스몰\n</td><td rowspan=\"3\">\n\n공유불가\n</td><td>\n\n1.2GB\n</td></tr><tr><td>\n\n미디엄\n</td><td>\n\n4GB\n</td></tr><tr><td>\n\n라지\n</td><td>\n\n30GB\n</td></tr><tr><td>\n\n패밀리\n</td><td colspan=\"2\">\n\n40GB\n</td></tr><tr><td>\n\nData<br class=\"idpt-mobile\"> 인피니티\n</td><td colspan=\"2\">\n\n80GB\n</td></tr><tr><td rowspan=\"4\">\n\nT플랜 시니어\n</td><td>\n\n안심2.8G\n</td><td rowspan=\"3\">\n\n공유불가\n</td><td rowspan=\"2\">\n\n기본 데이터 제공량 내 사용가능\n</td></tr><tr><td>\n\n안심4.5G\n</td></tr><tr><td>\n\n에센스\n</td><td>\n\n30GB\n</td></tr><tr><td>\n\n스페셜\n</td><td colspan=\"2\">\n\n40GB\n</td></tr><tr><td>\n\n0플랜\n</td><td>\n\n라지\n</td><td colspan=\"2\">\n\n40GB\n</td></tr></tbody></table>\n                        <!-- //230420 [MOZOP002-26745] -->\n                    </div></li>\n                <!-- 190712 삭제 -->\n                <!-- <li>\n                    \n<div class=\"idpt-faq-question\" role=\"button\" aria-pressed=\"false\">\n                        <img src=\"https://cdnw.tworld.co.kr/img/product/icon-question_m.png\" class=\"idpt-mobile\" alt=\"질문\">\n                        <img src=\"/poc/img/product/icon-question.png\" class=\"idpt-pc\" alt=\"질문\">\n                        <p>테더링은 얼마나 사용할 수 있나요?</p>\n                        <img src=\"https://cdnw.tworld.co.kr/img/product/faq-arrow_m.png\" class=\"idpt-mobile faq-arrow\" alt=\"답변 펼쳐보기\">\n                        <img src=\"/poc/img/product/faq-arrow.png\" class=\"idpt-pc faq-arrow\" alt=\"답변 펼쳐보기\">\n                    </div><div class=\"idpt-faq-answer\">\n                        <img src=\"https://cdnw.tworld.co.kr/img/product/icon-answer_m.png\" class=\"idpt-mobile\" alt=\"답변\">\n                        <img src=\"/poc/img/product/icon-answer.png\" class=\"idpt-pc\" alt=\"답변\">\n                        <p>요금제별 기본 데이터 내에서의 테더링 이용한도는 우측과 같습니다. 단, 공유 데이터 (가족공유, 선물하기, 함께쓰기, 2nd 디바이스 공유)와는 별도로 차감됩니다.</p><table class=\"idpt-tbl-discount\"><caption>요금제별 공유 데이터</caption><colgroup><col style=\"width:25%\"><col style=\"width:30%\"><col style=\"width:auto\"></colgroup><thead><tr><th colspan=\"2\">\n\n요금제명\n</th><th>\n\n이용한도\n</th></tr></thead><tbody><tr><td rowspan=\"2\">\n\n5GX 플랜\n</td><td>\n\n프라임\n</td><td>\n\n30GB\n</td></tr><tr><td>\n\n플래티넘\n</td><td>\n\n50GB\n</td></tr><tr><td rowspan=\"5\">\n\nT플랜\n</td><td>\n\n안심2.5G\n</td><td>\n\n2.5GB\n</td></tr><tr><td>\n\n안심4G\n</td><td>\n\n4GB\n</td></tr><tr><td>\n\n에센스\n</td><td>\n\n15GB\n</td></tr><tr><td>\n\n스페셜\n</td><td>\n\n20GB\n</td></tr><tr><td>\n\n맥스\n</td><td>\n\n30GB\n</td></tr><tr><td rowspan=\"3\">\n\nT플랜\n</td><td>\n\n라지\n</td><td>\n\n15GB\n</td></tr><tr><td>\n\n패밀리\n</td><td>\n\n20GB\n</td></tr><tr><td>\n\nData 인피니티\n</td><td>\n\n30GB\n</td></tr><tr><td>\n\n0플랜\n</td><td>\n\n라지\n</td><td>\n\n20GB\n</td></tr></tbody></table>\n                        <p class=\"answer-title\">테더링 설정방법</p>\n                        <p class=\"answer-txt with-title\">아이폰 설정</p>\n                        \n<div class=\"answer-img\">\n                            <img src=\"https://cdnw.tworld.co.kr/img/product/iphone-setting_m.png\" class=\"idpt-mobile\" alt=\"설정 > 개인용 핫스팟\">\n                            <img src=\"/poc/img/product/iphone-setting.png\" class=\"idpt-pc\" alt=\"설정 > 개인용 핫스팟\">\n                        </div><p class=\"answer-txt\">안드로이드 설정</p>\n                        \n<div class=\"answer-img\">\n                            <img src=\"https://cdnw.tworld.co.kr/img/product/android-setting_m.png\" class=\"idpt-mobile\" alt=\"연결 > 모바일 핫스팟 및 테더링\">\n                            <img src=\"/poc/img/product/android-setting.png\" class=\"idpt-pc\" alt=\"연결 > 모바일 핫스팟 및 테더링\">\n                        </div></div></li> -->\n                <!-- //190712 삭제 -->\n                \n<li>\n                    \n<div class=\"idpt-faq-question\" role=\"button\" aria-pressed=\"false\">\n                        \n                        \n                        <p>저는 Data 인피니티(또는 패밀리)사용자인데요. 가족 별 데이터 및 요금제의 남은 데이터양은 어디서 확인하나요?</p>\n                        \n                        \n                    </div><div class=\"idpt-faq-answer\">\n                        \n                        \n                        <p>my T &gt; ‘나의 데이터·통화’에서 나의 잔여 데이터양은 물론 공유된 가족간 사용 데이터양도 확인 가능합니다.</p>\n                        \n<div class=\"answer-img\">\n                            \n                            \n                        </div></div></li>\n            \n</ul>\n        </div><!-- ADMIN 등록 스크립트 영역에는 주석 금지. ADMIN 등록 시 줄바꿈이 없어지는 경우가 있어서 오류 발생함. -->                <!--// ADMIN 등록 스크립트 영역에는 주석 금지. ADMIN 등록 시 줄바꿈이 없어지는 경우가 있어서 오류 발생함. --></div>",
