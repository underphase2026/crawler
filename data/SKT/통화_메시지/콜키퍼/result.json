    "usageGuidelines": "<div class=\"divDetailInfoContents adaptive-visualization\" data-contentidx=\"2\" style=\"display: none;\">\n                <div class=\"adaptive-belt-1000\">\n                    <div class=\"adaptive-belt-w1000\"> <div class=\"prCont-txt\">\n                                <table width=\"100%\" border=\"1\"><!-- 240723 [MOZOP002-35512] -->\n                                    <caption>가입/해지 방법 안내 - 유형, 가입/해지채널, 상세경로로 구성되어 있습니다.</caption><!-- 240723 [MOZOP002-35512] -->\n                                    <!-- 240723 [MOZOP002-35512] -->\n                                    <colgroup>\n                                        <col style=\"width:20%\">\n                                        <col style=\"width:30%\">\n                                        <col style=\"width:50%\">\n                                    </colgroup>\n                                    <thead><tr><th scope=\"col\">유형</th><th scope=\"col\">가입/해지 채널</th><th scope=\"col\">상세경로</th></tr></thead>\n                                    <!-- 240723 [MOZOP002-35512] -->\n                                    <tbody><!-- 220414 [MOZOP002-20307] -->\n                                        <tr><th rowspan=\"5\" scope=\"row\"> 가입 </th><td> T World </td><td> 부가서비스 &gt; 통화/메시지 &gt; 콜키퍼 </td></tr><tr><td> 모바일 고객센터 </td><td> 부가서비스 &gt; 통화/메시지 &gt; 콜키퍼 </td></tr><tr><td> 고객센터 </td><td> 02-1599-0011 / SK 텔레콤 휴대폰으로 지역번호없이 114 </td></tr><tr><td> 지점/대리점 </td><td> - </td></tr><tr><td> 기타외부채널 </td><td> T 통화매니저앱 &gt; 콜키퍼 검색 &gt; 가입 </td><!-- 230120 [MOZOP002-25157] --></tr><tr><th rowspan=\"5\" scope=\"row\"> 해지 </th><td> T World </td><td> 부가서비스 &gt; 통화/메시지 &gt; 콜키퍼 </td></tr><tr><td> 모바일 고객센터 </td><td> 부가서비스 &gt; 통화/메시지 &gt; 콜키퍼 </td></tr><tr><td> 고객센터 </td><td> 02-1599-0011 / SK 텔레콤 휴대폰으로 지역번호없이 114 </td></tr><tr><td> 지점/대리점 </td><td> - </td></tr><tr><td> 기타외부채널 </td><td> T 통화매니저앱 &gt; MY &gt; 콜키퍼 해지 </td><!-- 230120 [MOZOP002-25157] --></tr><!-- //220414 [MOZOP002-20307] -->\n      