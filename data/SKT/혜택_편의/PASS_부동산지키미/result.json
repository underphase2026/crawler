    "usageGuidelines": "<div class=\"divDetailInfoContents adaptive-visualization\" data-contentidx=\"2\" style=\"display: none;\">\n                <div class=\"adaptive-belt-1000\">\n                    <div class=\"adaptive-belt-w1000\"><div class=\"prCont-txt\">\n                                <!-- 210728 [OP002-16142] 수정_03 -->\n                                \n<table width=\"100%\" border=\"1\" summary=\"PASS 부동산지키미 유형(가입/해지), 가입/해지 경로, 방법을 설명하는 표입니다.\"><caption>가입/해지 안내</caption><thead><tr><th scope=\"col\" width=\"20%\">\n유형\n</th><th scope=\"col\" width=\"30%\">\n가입/해지 경로\n</th><th scope=\"col\" width=\"50%\">\n방법\n</th></tr></thead>\n                                    \n<tbody><tr><th scope=\"row\">\n가입\n</th><td>\nPASS 앱\n</td><td>\nPASS 앱 &gt; ‘전체’ &gt; ‘신용/자산’ &gt; ‘부동산’\n</td></tr><tr><th scope=\"row\" rowspan=\"3\">\n해지\n</th><td>\nPASS 앱\n</td><td>\nPASS 앱 &gt; ‘전체’ &gt; ‘설정’ &gt; ‘서비스 설정/해지관리‘\n</td></tr><tr><td>\nSKT 고객센터\n</td><td>\n1599-0011 (SKT 고객센터), 1600-1533 (부동산지키미 고객센터)\n</td><!-- 220406 [MOZOP002-20200] --><!-- 220822 [MOZOP002-22585] -->\n                                    \n</tr><tr><td>\nT world 홈페이지/앱\n</td><td>\nT world &gt; 'PASS 부동산지키미' 검색 &gt; 자세히 보기\n</td></tr></tbody></table>\n                                <!-- //210728 [OP002-16142] 수정_03 -->\n                            </div></div>\n                </div>\n            </div>",
    "notices": "<div class=\"divDetailInfoContents adaptive-visualization\" data-contentidx=\"3\" style=\"display: none;\">\n                <div class=\"adaptive-belt-1000\">\n                    <div class=\"adaptive-belt-w1000\"><!-- ##### admin 등록 영역 ##### -->                            <div class=\"prCont-txt\">\n                                <!-- 210728 [OP002-16142] 수정_04 -->\n                                \n<ul>\n                                    \n<li>해지 시 이용요금은 이용한 기간만큼 하루 단위로 계산하여 청구되며, 가입 당일 해지 시 요금이 청구되지 않습니다.</li>\n                                    \n<li>피처폰, 선불폰, 법인폰, 해외에 계시는 고객님, 알뜰폰(MVNO) 이용 고객님 및 만 19세 미만 고객님은 가입하실 수 없습니다.</li>\n                                    \n<li>휴대폰을 일시 정지하신 경우 서비스를 이용하실 수 없습니다.(이 경우 이용요금이 청구되지 않습니다.)</li>\n                                    \n<li>PASS 앱이 아닌 다른 경로로 가입하신 경우 ‘부동산지키미’ 서비스로 가입됩니다.</li><!-- 220406 [MOZOP002-20200] -->\n                                \n</ul>\n                                <!-- //210728 [OP002-16142] 수정_04 -->\n                            </div><p><br><br><br></p><!-- //##### admin 등록 영역 ##### --></div>\n                </div>\n            </div>"
