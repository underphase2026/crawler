/유선 요금제(인터넷 요금제 or 전화 요금제 or TV 요금제) -->\n           \n           <div class=\"adaptive-float-area-price-money\">990원\n           \t\t\n           </div>\n           \n\t           \n\t       \n        </div>\n<hr class=\"section-divider\">\n<div class=\"adaptive-float-area-summary C\">\n            <!-- 무선 요금제 -->\n            \n            <!-- //무선 요금제 -->  \n            <!-- 무선 부가서비스 -->\n            \n            <!-- //무선 부가서비스 -->  \n            <!-- 로밍 요금제 -->\n            \n            \n            <!-- //로밍 요금제 -->\n        </div>\n<hr class=\"section-divider\">\n<div class=\"adaptive-belt-w1000\"><!-- 210827 [OP002-16751] 변경_02 -->            <div class=\"idpt-benefit no-button benefit-white\">\n                <p class=\"benefit-title\">미리 설정해 둔 음성 메모로 중요한 일정 알림<br class=\"idpt-pc\">나만의 다짐도 반복해 들으며 작심삼일 극복</p>\n                \n<div class=\"idpt-join-info\">\n                    \n<div class=\"benefit-img\">\n                        \n                        \n                    </div><div class=\"join-info-txt\">\n                        <p>상대방에게 전화를 걸 때마다 통화 연결 전에 기념일, 일정 등<br>설정된 메모를 들려 드려요.<br>반복 청취 기능을 통해 소중한 사람 그리고 자신과의 약속도<br>지켜 보세요.</p>\n                    </div></div></div><!-- //210827 [OP002-16751] 변경_02 --><!--// T메모링 설명 -->            <!-- T메모링 제공 서비스 -->            <div class=\"idpt-benefit no-button benefit-gray\">\n                \n<ul class=\"idpt-title-bg-box\">\n                    \n<li>\n                        <p class=\"benefit-title\">음성 메모로 중요 일정을 쉽게 기억</p>\n                        \n<div class=\"display-flex\">\n                            \n                            \n                            \n<div>\n                                <p class=\"sub-title\">전화 받는 분의 기념일을 음성 메모로 쉽게 기억</p>\n                                <p class=\"sub-txt\">전화 받는 분 마다 개별로 음성 메모를 등록할 수 있어서, 전화를 걸 때마다 생일 등 중요한 기념일을 쉽게 알려줍니다.</p>\n                            </div></div></li>\n                    \n<li>\n                        <p class=\"benefit-title\">주요 명절 등 기본 콘텐츠 제공</p>\n                        \n<div class=\"display-flex\">\n                            \n                            \n                            \n<div>\n                                <p class=\"sub-title\">이야깃거리가 있는 재미있는 콘텐츠 제공</p>\n                                <p class=\"sub-txt\">명절, 24절기 등 기타 이야깃거리가 있는 재미있는 일정에 대한 콘텐츠와 다이어트, 명언 등 테마도 제공합니다.</p>\n                            </div></div></li>\n                    \n<li>\n                        <p class=\"benefit-title\">지정한 일정에 반복 알림</p>\n                        \n<div class=\"display-flex\">\n                            \n                            \n                            \n<div>\n                                <p class=\"sub-title\">지정한 요일과 시간에 반복 알림</p>\n                                <p class=\"sub-txt\">지정한 요일과 시간에 따라 매주 메모링을 반복적으로 들려 줍니다.</p>\n                            </div></div></li>\n                \n</ul>\n            </div><!--// T메모링 제공 서비스 -->            <!-- 이용요금 안내 -->            <div class=\"idpt-benefit no-button benefit-white\">\n                <p class=\"benefit-title\">이용요금</p>\n                \n<div class=\"idpt-charge-info\">\n                    \n<div class=\"charge\">\n                        <p class=\"navy with-icon\"><span>990</span>원(부가세 포함)</p>\n                    </div></div><ul class=\"idpt-dot-list with-border\">\n                    \n<li>서비스 해지 시 요금은 일할 과금됩니다. </li>\n                \n</ul>\n            </div><!--// 이용요금 안내 -->            <!-- 앱 이용방법 안내 -->            <div class=\"idpt-benefit benefit-gray\">\n                <p class=\"benefit-title\">앱 이용방법</p>\n                \n<ul class=\"idpt-circle-list navy\">\n                    \n<li class=\"clearfix\">\n                        <p class=\"num\">1</p>\n                        \n<div class=\"txt-area\">\n                            <p class=\"circle-list-title\">앱 다운로드 및 설치</p>\n                            <p class=\"circle-list-txt\">원스토어에서 'T메모링' 앱 검색 후 설치</p>\n                            \n<div class=\"benefit-button static\">\n                                <a href=\"https://www.onestore.co.kr/userpoc/apps/view?pid=0000654435\" class=\"button-more fe-link-external idpt-pc\" target=\"_blank\">원스토어 바로가기</a>\n                                <a href=\"https://m.onestore.co.kr/mobilepoc/apps/appsDetail.omp?prodId=0000654435\" class=\"button-more fe-link-external idpt-mobile\" target=\"_blank\">원스토어 바로가기</a>\n                            </div></div><div class=\"arrow\">&nbsp;</div></li>\n                    \n<li class=\"clearfix\">\n                        <p class=\"num\">2</p>\n                        \n<div class=\"txt-area\">\n                            <p class=\"circle-list-title\">앱 실행 후 서비스 가입하기</p>\n                        </div><div class=\"arrow\">&nbsp;</div></li>\n                    \n<li class=\"clearfix\">\n                        <p class=\"num\">3</p>\n                        \n<div class=\"txt-area\">\n                            <p class=\"circle-list-title\">T 메모링 서비스 이용하기</p>\n                            <p class=\"circle-list-txt\">기본 콘텐츠, 개인별 맞춤 메모 등 T메모링에서 제공하는 음성 메모 기능을 이용하시면 됩니다.</p>\n                        </div></li>\n                \n</ul>\n            </div><!--// 앱 이용방법 안내 -->            <!-- 사용방법 안내 -->            <div class=\"idpt-benefit benefit-white\">\n                <p class=\"benefit-title\">이용방법</p>\n                \n<ul class=\"idpt-bg-list no-bg\">\n                    \n<li>\n                        \n<div>\n                            <p class=\"idpt-bg-list-title\">서비스 이용방법</p>\n                            <p class=\"idpt-bg-list-txt\">- 날짜, 시간, 개인별로 메모를 기입 또는 녹음하면 전화를 걸 때 해당 메모를 음성으로 들려주고 통화 연결이 시작됩니다.</p>\n                        </div></li>\n                    \n<li style=\"border-top:0\">\n                        \n<div>\n                            <p class=\"idpt-bg-list-title\">서비스 제공 기능</p>\n                            <p class=\"idpt-bg-list-txt\">- 기본콘텐츠: 주요 명절, 24절기, 기타 이야깃거리가 있는 재미있는 날로 구성</p>\n                            <p class=\"idpt-bg-list-txt\">- UCC: 텍스트 입력, 음성 녹음, 저장된 음원을 편집하여 메모링을 제작할 수 있으며, 제작된 메모링은 주간 반복, 특정일, 개인별로 설정할 수 있습니다.</p>\n                            <p class=\"idpt-bg-list-txt\">- 개인별 메모링: 이용자가 원하는 연락처별로 설정할 수 있습니다.</p>\n                            <p class=\"idpt-bg-list-txt\">- 추천 메모링: 다이어트, 자기 관리, 힐링, 명언, 금연 등 다양한 주제의 콘텐츠로 구성</p>\n                            <p class=\"idpt-bg-list-txt\">- 주간 메모링: 지정한 요일과 시간대에 매주 메모링을 반복적으로 들려 줍니다.</p>\n                            <p class=\"idpt-bg-list-txt\">- 특정일 메모링: 특정한 날짜를 지정하여 설정할 수 있습니다.</p>\n                        </div></li>\n                \n</ul>\n            </div></div>",
