->\n           \n           <div class=\"adaptive-float-area-price-money\">무료\n           \t\t\n           </div>\n           \n\t           \n\t       \n        </div>\n<hr class=\"section-divider\">\n<div class=\"adaptive-float-area-summary C\">\n            <!-- 무선 요금제 -->\n            \n            <!-- //무선 요금제 -->  \n            <!-- 무선 부가서비스 -->\n            \n            <!-- //무선 부가서비스 -->  \n            <!-- 로밍 요금제 -->\n            \n            \n            <!-- //로밍 요금제 -->\n        </div>\n<hr class=\"section-divider\">\n<div class=\"prCont left\">\n            <!-- 서비스 개요 -->\n            <!-- 휴대폰결제 비밀번호 안내 -->\n            \n<div class=\"idpt-benefit no-button benefit-white\">\n                <p class=\"benefit-title\">휴대폰 결제할 때 안전하게 한번 더 비밀번호 입력</p>\n                \n<div class=\"idpt-join-info\">\n                    \n<div class=\"benefit-img\">\n                        \n                        \n                    </div><div class=\"join-info-txt\">\n                        <p>별도 프로그램 설치하지 않고 한번의 비밀번호 설정으로<br>휴대폰결제 시 안전하게 결제할 수 있습니다.</p>\n                    </div></div></div><!--// 휴대폰결제 비밀번호 안내 -->\n            <!-- 휴대폰결제 비밀번호 정보 -->\n            \n<div class=\"idpt-benefit no-button benefit-gray\">\n                \n<ul class=\"idpt-title-bg-box\">\n                    \n<li>\n                        <p class=\"benefit-title\">6자리 비밀번호로 완벽 보안</p>\n                        \n<div class=\"display-flex\">\n                            \n                            \n                            \n<div>\n                                <p class=\"sub-title\">비밀번호 설정으로 안전한 휴대폰결제</p>\n                                <p class=\"sub-txt\">\n6자리 비밀번호를 설정하여 휴대폰 결제 시 안전하게 결제할 수 있습니다.\n</p>\n                            </div></div></li>\n                    \n<li>\n                        <p class=\"benefit-title\">비밀번호 입력 횟수 제한</p>\n                        \n<div class=\"display-flex\">\n                            \n                            \n                            \n<div>\n                                <p class=\"sub-title\">5회 이상 잘못 입력하면 잠금 상태로 변경</p>\n                                <p class=\"sub-txt\">\n비밀번호를 5회 이상 잘못 입력하면 잠금 상태가 되어 휴대폰 결제를 할 수 없게 됩니다.\n</p>\n                            </div></div></li>\n                \n</ul>\n            </div><!--// 휴대폰결제 비밀번호 정보 -->\n            <!-- 이용요금 안내 -->\n            \n<div class=\"idpt-benefit no-button benefit-white\">\n                <p class=\"benefit-title\">이용요금</p>\n                \n<div class=\"idpt-charge-info\">\n                    \n<div class=\"charge\">\n                        <p class=\"navy with-icon\">무료</p>\n                    </div></div><ul class=\"idpt-dot-list with-border\">\n                    \n<li>비밀번호를 설정하여 안전하게 결제를 하도록 지켜주는 무료 서비스입니다.</li>\n                \n</ul>\n            </div><!--// 이용요금 안내 -->\n            <!-- 앱 이용방법 안내 -->\n            \n<div class=\"idpt-benefit no-button benefit-gray\">\n                <p class=\"benefit-title\">이용방법</p>\n                \n<ul class=\"idpt-bg-list no-bg\">\n                    \n<li>\n                        <!-- 230228 [MOZOP002-25786] -->\n                        \n<div>\n                            <p class=\"idpt-bg-list-title\">비밀번호 설정 방법</p>\n                            <p class=\"idpt-bg-list-txt\">서비스 가입 후 확인 문자로 안내되는 특번ARS(1509)로 접속하여 비밀번호 설정 가능</p>\n                            <p class=\"idpt-bg-list-txt\">- (PC) myT &gt; 나의 가입정보 &gt; 나의 요금제/부가서비스/결합상품 &gt; 부가서비스 내 휴대폰결제 비밀번호 \"설정/변경\" &gt; [비밀번호 신규 등록]</p>\n                            <p class=\"idpt-bg-list-txt\" style=\"margin-top: 0.3125rem !important;\">- (APP) MY &gt; 휴대폰 결제/콘텐츠 이용료 &gt; #결제 비밀번호 신청</p>\n                        </div><!-- //230228 [MOZOP002-25786] -->\n                    </li>\n                    \n<li>\n                        \n<div>\n                            <p class=\"idpt-bg-list-title\">비밀번호 입력 횟수 제한</p>\n                            <p class=\"idpt-bg-list-txt\">\n휴대폰 결제 비밀번호를 5회 이상 잘못 입력할 경우 비밀번호는 잠금 상태로 변경되며, ARS(1509) 통해 비밀번호 재설정 후 이용할 수 있습니다.\n</p>\n                        </div></li>\n                    \n<li>\n                        \n<div>\n                            <p class=\"idpt-bg-list-title\">비밀번호 잠금 또는 분실 시</p>\n                            <p class=\"idpt-bg-list-txt\">\n휴대폰결제 비밀번호를 분실할 경우 또는 잠금 상태인 경우 ARS(1509) 통해 비밀번호 재설정 후 이용할 수 있습니다.\n</p>\n                        </div></li>\n                    \n<li>\n                        \n<div>\n                            <!-- 230228 [MOZOP002-25786] -->\n                            <p class=\"idpt-bg-list-title\">비밀번호 재설정(변경) 방법</p>\n                            <p class=\"idpt-bg-list-txt\">특번ARS(1509)로 접속 후 기존 비밀번호 인증 후 재설정</p>\n                            <p class=\"idpt-bg-list-txt\">- (PC) myT &gt; 나의 가입정보 &gt; 나의 요금제/부가서비스/결합상품 &gt; 부가서비스 내 휴대폰결제 비밀번호 \"설정/변경\" &gt; [비밀번호 변경]</p>\n                            <p class=\"idpt-bg-list-txt\" style=\"margin-top: 0.3125rem !important;\">- (APP) MY &gt; 휴대폰 결제/콘텐츠 이용료 &gt; #결제 비밀번호 변경</p>\n                            <!-- //230228 [MOZOP002-25786] -->\n                        </div></li>\n                \n</ul>\n            </div><!--// 앱 이용방법 안내 -->\n            <!--// 서비스 개요 --></div>",
    "usageGuidelines": "<div class=\"divDetailInfoContents adaptive-visualization\" data-contentidx=\"1\" style=\"display: none;\">\n                <div class=\"adaptive-belt-1000\">\n                    <div class=\"adaptive-belt-w1000\"><!-- ##### admin 등록 영역 ##### -->                            <div class=\"prCont-txt\">\n                                <!-- 211115 [OP002-17975 변경_01 -->\n                                \n<table width=\"100%\" border=\"1\" summary=\"휴대폰결제 비밀번호 가입/해지 방법을 유형, 가입/해지 채널, 상세경로로 설명합니다.\"><caption>휴대폰결제 비밀번호 가입/해지 방법 안내</caption><colgroup>\n                                    <col width=\"20%\">\n                                    <col width=\"30%\">\n                                    <col width=\"50%\">\n                                </colgroup>\n                                \n<thead><tr><th>\n유형\n</th><th>\n가입/해지 채널\n</th><th>\n상세경로\n</th></tr></thead>\n                                <!-- //211115 [OP002-17975 변경_01 -->\n                                \n<tbody><tr><th rowspan=\"3\">\n가입\n</th><td>\nT world\n</td><td>\nT world 접속 후 로그인 (인증개인회원만 가능)\n</td></tr><tr><td>\n고객센터\n</td><td>\n1599-0011 (SKT고객센터)\n</td></tr><tr><td>\n지점/대리점\n</td><td>\n본인이 신분증 지참 후 본인 확인 후 가입 가능\n</td></tr><tr><th rowspan=\"3\">\n해지\n</th><td>\nT world\n</td><td>\n1599-0011 (SKT고객센터)\n</td></tr><tr><td>\n고객센터\n</td><td>\n가입자 본인이 직접 내방하여 대리점/지점에 신분증 제시하여 본인 확인 후 해지 가능 1599-0011 (SKT고객센터)\n</td></tr><tr><td>\n지점/대리점\n</td><td>\n본인이 신분증 지참 후 본인 확인 후 가입 가능\n</td></tr></tbody></table>\n                            </div><!-- //##### admin 등록 영역 ##### --></div>\n                </div>\n            </div>",
    "notices": "<div class=\"divDetailInfoContents adaptive-visualization\" data-contentidx=\"2\" style=\"display: none;\">\n                <div class=\"adaptive-belt-1000\">\n                    <div class=\"adaptive-belt-w1000\"><div class=\"prCont-txt\"><ul> \n<li>서비스 가입 후에는 비밀번호 설정 필요 비밀번호 미 설정 시에는 ‘휴대폰결제 비밀번호'를 이용한 결제 진행 불가능</li> \n<li>회선 해지 및 명의 변경 시에는 부가서비스 자동 해지됨 (설정한 비밀번호도 자동 삭제됨)</li></ul></div></div>\n                </div>\n            </div>\n<hr class=\"section-divider\">\n<div class=\"divDetailInfoContents adaptive-visualization\" data-contentidx=\"4\" style=\"display: none;\">\n                <div class=\"adaptive-belt-1000\">\n                    <div class=\"adaptive-belt-w1000\"><div class=\"prCont-txt\"><ul> \n<li>설정하신 비밀번호를 절대 타인과 공유하셔서는 안되며, 통신사도 고객님께 어떠한 상황에서도 '휴대폰결제 비밀번호'를 문의하지 않으니 보안에 각별히 신경 써 주십시오.</li> \n<li>개인의 부주의로 인한 비밀번호 유출에 의한 부정 결제는 개인의 책임입니다.</li> \n<li>휴대폰결제 비밀번호 결제가 적용된 휴대폰액결제 서비스는 지속적으로 확대될 예정입니다.<br>- 2016년 6월 현재 : 대부분의 온라인 휴대폰 결제, 일부 콘텐츠 이용료 결제</li> \n<li>휴대폰결제 비밀번호 서비스 가입만으로 결제 안정성이 강화되는 것은 아니므로 휴대폰결제 비밀번호 가입 후 반드시 비밀번호를 설정해야 휴대폰 결제 시 한 번 더 비밀번호 확인을 통해 보다 안전한 결제가 가능합니다</li></ul></div></div>\n                </div>\n            </div>"
  }
