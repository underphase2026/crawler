<th:block th:switch=\"${resBasInfo[prodTypCd]}\"> -->\n<!-- \t\t                      <span th:case=\"F\" class=\"unable notlink\">결합상품신청</span> -->\n<!-- \t\t                      <span th:case=\"*\" class=\"unable notlink\">가입</span> -->\n<!-- \t\t                  </th:block> -->\n<!-- \t\t                </div> -->\n<!-- \t\t            </th:block>               -->\n\t            \n\t            <!-- //가입가능 상품 -->\n\t            <!-- 가입중단 상품 -->\n\t            \n\t            <!-- //가입중단 상품 -->\n\t            <!-- 가입불가 상품 -->\n\t            \n\t            <!-- //가입불가 상품 -->\n\t        \n\t    \n\t    <!-- //미가입 -->\n\t    <!-- 가입 -->\n\t    \n\t    <!-- //가입 -->\n      \t            \n\t            <!-- //버튼 -->\n\t            \n\t            <!-- 기본제공영역 -->\n                \n        <!-- 기본제공영역 -->\n        <div class=\"adaptive-float-area-summary C\">\n            <!-- 무선 요금제 -->\n            \n            <!-- //무선 요금제 -->  \n            <!-- 무선 부가서비스 -->\n            \n            <!-- //무선 부가서비스 -->  \n            <!-- 로밍 요금제 -->\n            \n            \n            <!-- //로밍 요금제 -->\n        </div>\n        <!-- //기본제공영역 -->\n      \n\t            <!-- //기본제공영역 -->\n\t            \n\t            <!-- SKT만의혜택영역 -->\n\t            \n\t            <!-- //SKT만의혜택영역 -->\n\t\n\t            <!-- 이용중인 상품영역 -->\n\t            \n\t    <!-- 이용중인 상품영역 -->\n\t    \n\t    \n\t       \t\n\t      \n\t          <!-- 인터넷 요금제, 전화 요금제, TV 요금제, 결합 요금제 -->\n\t          \n\t      \n\t    \n\t    <!-- //이용중인 상품영역 -->\n  \n\t            <!-- //이용중인 상품영역 -->\n\t        </div>\n<hr class=\"section-divider\">\n<div class=\"adaptive-float-area-price\">\n           <div class=\"adaptive-float-area-price-tit\" style=\"word-break: break-all;\">오토컬러링</div>\n           <!-- //무선 요금제 or 결합상품 -->\n           \n           <!-- //무선 부가서비스 or 로밍상품 or 유선 부가서비스(인터넷 부가서비스 or 전화 부가서비스 or TV 부가서비스) -->\n           <div class=\"adaptive-float-area-price-case\">이용요금(부가세 포함)</div>\n           <!-- //유선 요금제(인터넷 요금제 or 전화 요금제 or TV 요금제) -->\n           \n           <div class=\"adaptive-float-area-price-money\">1,650원\n           \t\t\n           </div>\n           \n\t           \n\t       \n        </div>\n<hr class=\"section-divider\">\n<div class=\"adaptive-float-area-summary C\">\n            <!-- 무선 요금제 -->\n            \n            <!-- //무선 요금제 -->  \n            <!-- 무선 부가서비스 -->\n            \n            <!-- //무선 부가서비스 -->  \n            <!-- 로밍 요금제 -->\n            \n            \n            <!-- //로밍 요금제 -->\n        </div>\n<hr class=\"section-divider\">\n<div class=\"adaptive-belt-w1000\"><div class=\"idpt-benefit no-button benefit-white\">\n                <p class=\"benefit-title\">장르 선택 시 5일마다 자동 변경</p>\n                <p class=\"benefit-desc\">원하는 장르만 선택하면 5일마다  컬러링이  자동으로 변경되는 똑똑한 컬러링 서비스 입니다.</p>\n                \n<ul class=\"benefit-data list02 clearfix\">\n                    \n<li>\n                        \n                        \n                        월 6회<br>자동변경\n                    </li>\n                    \n<li>\n                        \n                        \n                        실시간<br>음악변경\n                    </li>\n                \n</ul>\n                \n<ul class=\"idpt-dot-list with-border\">\n                    \n<li>5일마다 컬러링을 자동 변경시켜주는 서비스 입니다.<br>(자동 변경일 : 1, 6, 11, 16, 21, 26 일)</li>\n                    \n<li>내맘대로오토링, 오토컬러링, 컬러링무제한정액제와는 함께 가입할 수 없습니다.</li>\n                    \n<li>선불폰(PPS)*, PDA, 음성착발신이 불가능한 기기 이용 고객은 가입하실 수 없습니다.\n                        \n<ul class=\"idpt-dot-list with-title\">\n                            \n<li class=\"star\">선불폰(PPS) : 월정액 없이 선불카드 구입 후 일정 금액을 충전하여 해당 금액만큼 이용하는 서비스</li>\n                        \n</ul>\n                    </li>\n                \n</ul>\n            </div><!--// 장르 선택 시 5일마다 자동 변경 -->            <!-- 다양한 컬러링 -->            <div class=\"idpt-benefit no-button benefit-gray\">\n                \n<ul class=\"idpt-title-bg-box\">\n                    \n<li>\n                        <p class=\"benefit-title\">월 최대 10회 장르변경</p>\n                        \n<div class=\"display-flex\">\n                            \n                            \n<div>\n                                <p class=\"sub-txt\">음악 장르를 변경하는 경우 컬러링이 실시간으로 변경되며, 곡 정보(제목-가수)가 문자메시지(SMS)로 발송됩니다.<br>(가입 시, 기본 컬러링 / 최신 장르로 자동 설정됨)</p>\n                                <p class=\"sub-txt\">장르는 월 최대 10회까지 변경 가능하며, 변경횟수는 매월 1일 초기화 됩니다.</p>\n                            </div></div></li>\n                    \n<li>\n                        <p class=\"benefit-title\">똑똑한 컬러링 서비스</p>\n                        \n<div>\n                            \n                            \n                            \n<div>\n                                <p class=\"sub-txt\">선물 받은 컬러링을 포함하여 기본 컬러링 또는 발신자 별 컬러링 설정을 변경하면, 자동 변경주기 1회를 건너뛰고,그 다음 변경주기에 오토컬러링 음원으로 자동변경됩니다.</p>\n                                <p class=\"sub-txt\">이때 삭제된 컬러링은 오토컬러링 서비스 해지 또는 오토컬러링의 기본/발신자별 설정정보 변경하는 경우 복원됩니다.</p>\n                                <p class=\"sub-txt\">단, 시간대별 컬러링을 설정하거나 변경할 경우, 다음 변경주기에 자동으로 컬러링이 오토컬러링으로 변경됩니다.</p>\n                            </div></div></li>\n                    \n<li class=\"no-padding-bottom\">\n                        <p class=\"benefit-title\">컬러링 유지</p>\n                        \n<div>\n                            \n                            \n                            \n<div>\n                                <p class=\"sub-txt\">컬러링 유지란 현재 설정되어있는 컬러링을 오토컬러링 변경주기에 변경하지 않고 계속해서 유지하는 기능입니다.</p>\n                                <p class=\"sub-txt\">유지하기 서비스를 설정하는 경우 설정한 날부터 다음달까지 설정 당시 컬러링이 유지되다가 그 다음달 자동변경 주기에 오토컬러링 음원으로 자동 변경됩니다.</p>\n                                <p class=\"sub-txt\">유지기능 설정시에도 오토컬러링 정액요금이 부과됩니다.</p>\n                            </div></div></li>\n                \n</ul>\n            </div><!--// 다양한 컬러링 --><!-- 이용요금 안내 --><div class=\"idpt-benefit no-button benefit-white\">\n                <p class=\"benefit-title\">이용요금</p>\n                \n<div class=\"idpt-charge-info\">\n                    \n<div class=\"charge\">\n                        <p class=\"navy with-icon\">월 <span>1,650</span>원(부가세 포함)</p>\n                    </div></div><p class=\"benefit-txt align-center\">월정액 1,650원이 부과되는 정액제 가입 서비스입니다.<br>(부가세포함)<br><br>정액요금 이외 별도의 정보이용료는 없습니다.</p>\n                \n<ul class=\"idpt-dot-list\">\n                    \n<li>컬러링서비스 정액제 이용요금 990원(부가세포함)은 별도로 과금됩니다.</li><li>상품을 이용 중인 달에 중도 해지 시 이용 기간을 하루 단위로 계산해 요금이 청구됩니다.</li>\n                \n</ul></div><!--// 이용요금 안내 -->            <!-- 기본 컬러링/발신자 컬러링 설정 -->            <div class=\"idpt-benefit no-button benefit-gray\">\n                <p class=\"benefit-title\">기본 컬러링 · 발신자 컬러링 설정</p>\n                \n<div class=\"benefit-img\">\n                    \n                    \n                </div><p class=\"benefit-txt align-center\">기본 컬러링에서 발신자별 컬러링으로 변경하는 경우<br>기본 컬러링은 가장 최근에 설정하셨던<br class=\"idpt-mobile\"> 일반컬러링으로 변경됩니다.</p>\n                \n<div class=\"inside-box\">\n                    \n<div class=\"benefit-img no-margin-top\">\n                        \n                        \n                    </div><p class=\"benefit-txt align-center\">발신자별 컬러링에서 기본 컬러링으로 변경하는 경우<br>발신자별 컬러링은 가장 최근에 설정하셨던<br class=\"idpt-mobile\"> 일반컬러링으로 변경됩니다.</p>\n                </div><ul class=\"idpt-dot-list with-border\">\n                    \n<li>기본 컬러링 혹은 발신자 별 컬러링 중 선택하여 설정 가능합니다.<br>(발신자별 컬러링 선택 시, 1명만 설정 가능)</li>\n                    \n\n                    \n<li>자동변경을 발신자별 컬러링으로 설정하고, 발신자별 컬러링을 삭제하면 자동으로 기본 컬러링이 자동 변경됩니다.</li>\n                \n</ul>\n            </div><!--// 기본 컬러링/발신자 컬러링 설정 -->            <!-- 이용채널/이용내역 -->            <div class=\"idpt-benefit no-button benefit-white\">\n                <p class=\"benefit-title\">이용채널</p>\n                \n<ul class=\"idpt-dot-list-big with-title\">\n                    \n                    \n                    \n<li>온라인 T world &gt; 상품서비스 &gt; 모바일전용서비스 &gt; 컬러링/벨소리 &gt; 컬러링 &gt; 오토컬러링</li>\n                    \n<li>모바일 T world &gt; 부가서비스 &gt; 컬러링 &gt; 인기/최신컬러링 &gt; 오토컬러링</li>\n                    \n                \n</ul>\n            </div><p>&nbsp;</p></div>",
