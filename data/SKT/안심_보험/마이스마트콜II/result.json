  "content": {
    "details": "<div class=\"adaptive-float-area-frame\">\n\t            <!-- price 영역 -->\n                \n        <!-- price 영역 -->\n        <div class=\"adaptive-float-area-price\">\n           <div class=\"adaptive-float-area-price-tit\" style=\"word-break: break-all;\">마이스마트콜II</div>\n           <!-- //무선 요금제 or 결합상품 -->\n           \n           <!-- //무선 부가서비스 or 로밍상품 or 유선 부가서비스(인터넷 부가서비스 or 전화 부가서비스 or TV 부가서비스) -->\n           <div class=\"adaptive-float-area-price-case\">이용요금(부가세 포함)</div>\n           <!-- //유선 요금제(인터넷 요금제 or 전화 요금제 or TV 요금제) -->\n           \n           <div class=\"adaptive-float-area-price-money\">3,300원\n           \t\t\n           </div>\n           \n\t           \n\t       \n        </div>\n        <!-- //price 영역 -->\n                   \t            \n\t            <!-- //price 영역 -->\n\t            \n\t            <!-- 버튼 -->\n                \n\t    <!-- 미가입 -->\n\t    \n\t        \n\t            <!-- 가입가능 상품 -->\n\t            \n\t                \n\t\t                \n\t\t                    <div class=\"adaptive-float-area-join\">\n\t\t                        \n\t\t                        \t\n\t\t                        \t\n\t\t                        \t\t<a href=\"javascript:void(0);\" name=\"modalOpenBtn\" onclick=\"javascript:oTw.ProductCallplan.prototype._fnLoginCheck('01', &quot;\\/web\\/product\\/addon\\/join\\/{prodId}&quot;);\">가입</a>\n\t\t                        \t\n\t\t                        \n\t\t                        \n\t\t                    </div>\n\t\t                \n\t\t                    \n\t\t                   \n\t\t             \n\t\t            <!-- 인터넷 요금제 버튼설정 -->\n\t\t\t\t\t\n\t\t            <!-- //인터넷 요금제 버튼설정 -->\t\t\t\t\t\n<!-- \t\t            <th:block th:if=\"${(resBasInfo[linkBtnInfo][scrbBtn] eq 0) and (resBasInfo[prodScrbYn] eq 'N')}\">   -->\n<!-- \t\t                <div class=\"adaptive-float-area-join\"> -->\n<!-- \t\t                  <th:block th:switch=\"${resBasInfo[prodTypCd]